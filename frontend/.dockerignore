# Dependencies & build output (rebuilt inside the image)
node_modules
.next
out
dist
.turbo
.yarn/cache
.yarn/install-state.gz

# Source control & editor
.git
.gitignore
.gitattributes
.vscode
.idea
*.swp

# Env files — never bake secrets into the image
.env
.env.*
!.env.example

# Docs / agent rules — not needed at build time
*.md
CLAUDE.md
agents/

# Test artifacts
coverage
.nyc_output
playwright-report
test-results

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Docker-related (avoid recursive copy of Docker files into context)
Dockerfile*
.dockerignore
docker-compose*
docker-entrypoint.sh.bak

# Tauri / native shells — frontend Docker image doesn't need them
src-tauri
