{
  "name": "nextjs-heroui-kit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node ./scripts/sync-selfhost-public.mjs",
    "dev": "env-cmd -f .env next dev --turbopack -p 3000",
    "prebuild": "node ./scripts/sync-selfhost-public.mjs",
    "build": "next build --webpack",
    "build:icons": "tsc -b src/iconify-bundle && node src/iconify-bundle/bundle-icons-react.js",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css}\"",
    "preprocess-generated": "node ./src/api/generated/configs/pre-processor.js",
    "postprocess-generated": "node ./src/api/generated/configs/post-processor.js",
    "generate": "pnpm swagger-typescript-api -p ./src/api/generated/configs/main-service.swagger.json -o ./src/api/generated/main-service -n apiGenerated.ts --axios --unwrap-response-data",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "6.1.0",
    "@dnd-kit/modifiers": "7.0.0",
    "@dnd-kit/sortable": "8.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@emotion/is-prop-valid": "1.2.2",
    "@heroui/react": "2.7",
    "@hookform/resolvers": "5.2.0",
    "@iconify/react": "4.1.1",
    "@react-oauth/google": "0.13.4",
    "@react-pdf-viewer/core": "3.12.0",
    "@react-pdf-viewer/default-layout": "3.12.0",
    "@react-pdf-viewer/scroll-mode": "3.12.0",
    "@reduxjs/toolkit": "2.0.1",
    "@tanstack/react-query": "5.17.12",
    "@types/prismjs": "1.26.5",
    "@types/react-syntax-highlighter": "15.5.13",
    "@vercel/analytics": "1.6.1",
    "autoprefixer": "10.0.1",
    "axios": "1.6.5",
    "clsx": "2.1.1",
    "date-fns": "3.6.0",
    "dayjs": "1.11.10",
    "dotenv": "16.4.5",
    "env-cmd": "10.1.0",
    "framer-motion": "12.4.3",
    "i18next": "23.15.1",
    "i18next-browser-languagedetector": "8.0.0",
    "i18next-http-backend": "2.6.1",
    "iconify-icon": "2.3.0",
    "js-cookie": "3.0.5",
    "lightbox.js-react": "1.1.4",
    "next": "16",
    "next-themes": "0.4.4",
    "pdfjs-dist": "3.11.174",
    "postcss": "8",
    "qorstack-report-sdk": "0.0.1",
    "react": "19",
    "react-day-picker": "8.10.0",
    "react-dom": "19",
    "react-dropzone": "14.2.3",
    "react-hook-form": "7.51.5",
    "react-i18next": "15.0.2",
    "react-modern-drawer": "1.2.2",
    "react-redux": "9.1.0",
    "react-simple-code-editor": "0.14.1",
    "react-syntax-highlighter": "16.1.0",
    "recharts": "2.12.7",
    "redux": "5.0.1",
    "refractor": "5.0.0",
    "socket.io-client": "4.7.5",
    "swiper": "11.1.14",
    "tailwind-merge": "2.3.0",
    "use-debounce": "10.0.3",
    "usehooks-ts": "3.1.0",
    "xlsx": "0.18.5",
    "yup": "1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3",
    "@iconify-json/solar": "1.2.2",
    "@iconify/json": "2.2.34",
    "@iconify/tools": "2.2.6",
    "@iconify/types": "2.0.0",
    "@iconify/utils": "2.1.5",
    "@tauri-apps/cli": "1.6.1",
    "@types/js-cookie": "3.0.6",
    "@types/node": "22",
    "@types/react": "19",
    "@types/react-dom": "19",
    "eslint": "9",
    "eslint-config-next": "16",
    "husky": "9",
    "lint-staged": "15",
    "prettier": "3.2.5",
    "prettier-plugin-tailwindcss": "0.5.14",
    "swagger-typescript-api": "13.0.13",
    "tailwindcss": "3.4.1",
    "typescript": "5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --no-warn-ignored"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "neverBuiltDependencies": [
      "canvas"
    ]
  }
}
