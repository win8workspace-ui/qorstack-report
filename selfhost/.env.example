ADMIN_EMAIL=admin
ADMIN_PASSWORD=admin

DB_HOST=qorstack-postgres
DB_PORT=5432
DB_NAME=qorstack_report
DB_USER=postgres
DB_PASSWORD=change-me-db-password

MINIO_ENDPOINT=qorstack-minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-minio-secret

JWT_KEY=change-me-jwt-signing-key-at-least-32-chars
ENCRYPTION_KEY=change-me-encryption-key-32char!
ENCRYPTION_IV=change-me-iv-16!

API_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:3000
FRONTEND_PORT=3000

# Image versions — leave unset to track :latest, or pin for reproducible deploys.
# REPORT_API_TAG=latest
# REPORT_WEB_TAG=latest
