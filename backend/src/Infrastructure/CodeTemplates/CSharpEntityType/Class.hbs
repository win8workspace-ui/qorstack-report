{{> imports}}

namespace {{namespace}}
{
    {{#if comment}}
    /// <summary>
{{comment}}
    /// </summary>
    {{/if}}
    {{#each class-annotations}}
    {{{class-annotation}}}
    {{/each}}
    {{#unless (starts-with class "Log")}}
    public partial class {{class}} : BaseAuditableEntity
    {{else}}
    public partial class {{class}}
    {{/unless}}
    {
        {{{> properties}}}
    }
}
